# MongoDB Backup Strategy — Environment Variables
# Copy this file to .env and fill in your actual values
# Never commit the .env file to GitHub

# Source cluster (your main backup-test-cluster)
MONGO_URI=mongodb://YOUR_USER:YOUR_PASSWORD@shard-00-00.xxxxx.mongodb.net:27017,shard-00-01.xxxxx.mongodb.net:27017,shard-00-02.xxxxx.mongodb.net:27017/?ssl=true&replicaSet=atlas-xxxxx&authSource=admin

# Target cluster (your restore-cluster, used for disaster recovery testing)
MONGO_RESTORE_URI=mongodb://YOUR_RESTORE_USER:YOUR_RESTORE_PASSWORD@shard-00-00.yyyyy.mongodb.net:27017,shard-00-01.yyyyy.mongodb.net:27017,shard-00-02.yyyyy.mongodb.net:27017/?ssl=true&replicaSet=atlas-yyyyy&authSource=admin

# ── S3 backup (backup-s3.js) ──────────────────────────────────
S3_BUCKET_NAME=your-s3-bucket-name
AWS_REGION=ap-south-1
# AWS credentials are normally picked up automatically if running on an
# EC2 instance with an attached IAM role. If running locally, also set:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# ── AIMS Incident API (aimsIncident.js) ───────────────────────
# Same values used in the aws-deployment-backend repo — must match.
AIMS_BASE_URL=https://aims.erpica.in/api/v1/public/incidents
AIMS_API_KEY=paste_your_real_or_test_key_here
